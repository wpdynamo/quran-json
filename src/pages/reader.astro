---
import Layout from '../layouts/Layout.astro';
import Icons from '../components/Icons.astro';
---

<Layout 
  title="قارئ القرآن الكريم | Quran Reader" 
  description="اقرأ واستمع للقرآن الكريم مع الترجمة الإنجليزية. اختر من بين أشهر القراء مثل مشاري العفاسي وعبد الباسط عبد الصمد. تشغيل تلقائي للآيات."
  currentPage="reader"
>
    <script>
        import quranReader from '../scripts/quranReader.js';
        
        document.addEventListener('alpine:init', () => {
            // @ts-ignore
            Alpine.data('quranReader', quranReader);
        });
    </script>

    <div x-data="quranReader()" x-init="loadChapters()">
        <section class="controls-section" aria-label="إعدادات القراءة">
            <div class="controls-wrapper">
                <div class="control-row">
                    <label for="surahSelect" class="control-label">السورة</label>
                    <select id="surahSelect" x-model="selectedSurah" @change="loadSurah()" aria-label="اختر السورة">
                        <option value="">اختر...</option>
                        <template x-for="chapter in chapters" :key="chapter.id">
                            <option :value="chapter.id" x-text="`${chapter.id}. ${chapter.name_arabic}`"></option>
                        </template>
                    </select>
                </div>
                
                <div class="control-row">
                    <label for="reciterSelect" class="control-label">القارئ</label>
                    <select id="reciterSelect" x-model="selectedReciter" aria-label="اختر القارئ">
                        <option value="7">مشاري العفاسي</option>
                        <option value="1">عبد الباسط</option>
                        <option value="2">السديس</option>
                        <option value="3">عبد الله بصفر</option>
                        <option value="4">الشاطري</option>
                        <option value="5">هاني الرفاعي</option>
                    </select>
                </div>
                
                <div class="control-row control-row-toggle">
                    <span class="control-label">الترجمة</span>
                    <label class="toggle-switch" for="translationToggle">
                        <input type="checkbox" id="translationToggle" x-model="showTranslation">
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </section>

        <div class="container">
            <div x-show="loading" class="loading">جاري التحميل</div>
            
            <div x-show="!loading && !selectedSurah" class="empty-state">
                <div class="empty-state-icon"><Icons name="bookOpen" size={56} /></div>
                <div class="empty-state-text">اختر سورة من القائمة أعلاه للبدء</div>
            </div>

            <template x-if="!loading && selectedSurah && currentChapter">
                <div>
                    <div class="surah-header">
                        <div class="surah-name-wrapper">
                            <span class="surah-ornament">﴿</span>
                            <div class="surah-name-container">
                                <h2 class="surah-name" x-text="currentChapter.name_arabic"></h2>
                                <p class="surah-name-english" x-text="currentChapter.name_english"></p>
                            </div>
                            <span class="surah-ornament">﴾</span>
                        </div>
                        <div class="surah-meta">
                            <div class="surah-meta-item">
                                <span class="surah-meta-icon" x-html="currentChapter.revelation_place === 'makkah' ? '<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;16&quot; height=&quot;16&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot;><path d=&quot;M12 2L4 6v12l8 4 8-4V6l-8-4zm0 2.5l5 2.5v8l-5 2.5-5-2.5v-8l5-2.5z&quot;/><rect x=&quot;10&quot; y=&quot;8&quot; width=&quot;4&quot; height=&quot;6&quot; fill=&quot;white&quot;/></svg>' : '<svg xmlns=&quot;http://www.w3.org/2000/svg&quot; width=&quot;16&quot; height=&quot;16&quot; viewBox=&quot;0 0 24 24&quot; fill=&quot;none&quot; stroke=&quot;currentColor&quot; stroke-width=&quot;2&quot; stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot;><path d=&quot;M12 2L8 6v2H6v14h12V8h-2V6l-4-4z&quot;/><path d=&quot;M8 8h8&quot;/><path d=&quot;M10 12h4&quot;/><path d=&quot;M10 16h4&quot;/></svg>'"></span>
                                <span class="surah-meta-value" x-text="currentChapter.revelation_place === 'makkah' ? 'مكية' : 'مدنية'"></span>
                            </div>
                            <div class="surah-meta-item">
                                <span class="surah-meta-icon"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg></span>
                                <span class="surah-meta-value" x-text="currentChapter.verses_count + ' آية'"></span>
                            </div>
                        </div>
                    </div>

                    <template x-for="(verse, index) in verses" :key="index">
                        <div class="verse-container" :class="{ 'playing': playingIndex === index }">
                            <div class="verse-header">
                                <span class="verse-number" x-text="verse.a"></span>
                                <button class="btn btn-play" @click="playVerse(index)">
                                    <Icons name="play" size={14} />
                                    <span>استمع</span>
                                </button>
                            </div>
                            <div class="verse-arabic" x-text="verse.ar"></div>
                            <div class="verse-english" x-show="showTranslation" x-html="verse.en"></div>
                        </div>
                    </template>
                </div>
            </template>
        </div>

        <div class="audio-player" :class="{ 'active': isPlaying }">
            <div class="audio-info">
                <Icons name="headphones" size={18} />
                <span x-text="nowPlayingText"></span>
            </div>
            <div class="audio-controls">
                <button @click="stopAudio()">
                    <Icons name="stop" size={16} />
                    <span>إيقاف</span>
                </button>
            </div>
        </div>

        <audio x-ref="audio" preload="metadata" @ended="onAudioEnded()"></audio>
    </div>
</Layout>
