---
import Icons from './Icons.astro';
const { currentPage } = Astro.props;
---

<header class="header">
    <nav class="nav-bar" aria-label="التنقل الرئيسي">
        <a href="/" class="logo" aria-label="الصفحة الرئيسية">
            <Icons name="mosque" size={20} />
            <span>Quran API</span>
        </a>
        <div class="nav-links">
            <a href="/reader" class:list={["nav-link", { active: currentPage === 'reader' }]}>القارئ</a>
        </div>
    </nav>
</header>
